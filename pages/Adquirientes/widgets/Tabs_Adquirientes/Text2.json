  "text": "{{\n  (() => {\n    const total = (Query_Adq_Global.data || [])\n      .reduce((acc, row) => acc + (row.valor_usd || 0), 0);\n\n    const pagado = (Query_Adq_Global.data || [])\n      .reduce((acc, row) => acc + (row.total_pagado_usd || 0), 0);\n\n    const porcentaje = total > 0 ? (pagado / total) * 100 : 0;\n\n    return porcentaje.toLocaleString(\"en-US\", {\n      minimumFractionDigits: 2,\n      maximumFractionDigits: 2\n    }) + \"%\";\n  })()\n}}",
